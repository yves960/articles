{
  "name": "@zoo/memory-sdk",
  "version": "0.1.0",
  "description": "Agent Memory System - Persistent memory for AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/server.d.ts",
      "import": "./dist/mcp/server.js"
    }
  },
  "bin": {
    "memory-cli": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "example": "bun run src/example.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "cli": "bun run src/cli/index.ts",
    "mcp": "bun run src/mcp/server.ts",
    "lint": "echo 'No linter configured'"
  },
  "keywords": [
    "ai",
    "agent",
    "memory",
    "claude",
    "claude-code",
    "persistent-memory",
    "semantic-search",
    "mcp",
    "model-context-protocol"
  ],
  "author": "zoo",
  "license": "MIT",
  "dependencies": {
    "chromadb": "^1.8.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
